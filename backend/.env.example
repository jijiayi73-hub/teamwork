# 应用环境配置
APP_ENV=development

# 数据库配置（生产环境请使用 PostgreSQL）
DATABASE_URL=sqlite:///./data/app.db

# 安全密钥（生产环境请使用强随机密钥，建议至少 32 字符）
# 生成方式：python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-minimum-32-bytes

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=console

# CORS 配置（生产环境请修改为你的域名）
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# ============================================================================
# AI 提供商配置
# ============================================================================

# 选择 AI 提供商: openai 或 deepseek
AI_PROVIDER=openai

# OpenAI 配置（当 AI_PROVIDER=openai 时使用）
OPENAI_API_KEY=sk-your-openai-api-key-here
AI_DEFAULT_MODEL=gpt-4o-mini

# Deepseek 配置（当 AI_PROVIDER=deepseek 时使用）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
# AI_DEFAULT_MODEL=deepseek-chat

# ============================================================================
# 火山引擎 Ark API 配置（豆包文生图）
# ============================================================================

# Volces Ark API Key（用于豆包文生图）
VOLCES_API_KEY=	
# 或使用 ARK_API_KEY（兼容环境变量名）
# ARK_API_KEY=your-volces-api-key-here

# Volces Ark Base URL（默认北京区域）
VOLCES_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Volces 默认图像生成模型
VOLCES_IMAGE_MODEL=doubao-seedream-5-0-260128

# AI 超时设置（秒）
AI_TIMEOUT=30

# ============================================================================
# 火山引擎 TTS 配置（豆包双向流式语音合成）
# ============================================================================

# Volcengine TTS API Key（必需，从火山引擎控制台获取）
VOLCENGINE_TTS_API_KEY=

# Resource ID（决定模型版本和计费方式）
# seed-tts-2.0 - Seed-TTS 2.0 模型（推荐，支持更多音色和情绪）
# seed-tts-1.0 - Seed-TTS 1.0 模型
# seed-tts-1.0-concurr - Seed-TTS 1.0 并发版本
VOLCENGINE_TTS_RESOURCE_ID=seed-tts-2.0

# TTS WebSocket 端点（通常无需修改）
VOLCENGINE_TTS_ENDPOINT=wss://openspeech.bytedance.com/api/v3/tts/bidirection

# 默认音色（常用音色）
# zh_female_qingxin - 女声清新（推荐）
# zh_female_wanxiaomei - 女声婉小妹
# zh_male_zhiboshenquan - 男声之博深情
# zh_male_zhiboyangguang - 男声之博阳光
# zh_female_qiaoke - 女声可可
# zh_male_wukong - 男声悟空
VOLCENGINE_TTS_SPEAKER=zh_female_qingxin

# 旧版控制台支持（可选，如果使用旧版控制台）
# VOLCENGINE_TTS_APP_ID=your-app-id
# VOLCENGINE_TTS_ACCESS_KEY=your-access-key

# ============================================================================
# 邮箱服务配置（密码重置功能）
# ============================================================================
