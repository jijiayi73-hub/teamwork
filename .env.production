# ==============================================================================
# Inner Garden Production Environment Configuration
# ==============================================================================
# This file contains production environment variables for Inner Garden deployment
# Copy this to .env on the VPS and update the values
# ==============================================================================

# ----------------------------------------------------------------------------
# Application Configuration
# ----------------------------------------------------------------------------
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000

# ----------------------------------------------------------------------------
# Database Configuration
# ----------------------------------------------------------------------------
# SQLite for simplicity (can be upgraded to PostgreSQL later)
DATABASE_URL=sqlite:///./data/app.db

# PostgreSQL alternative (uncomment and configure if using PostgreSQL)
# DATABASE_URL=postgresql://user:password@localhost:5432/innergarden

# ----------------------------------------------------------------------------
# Security Configuration
# ----------------------------------------------------------------------------
# Generate a secure key with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_KEY_MINIMUM_32_BYTES

# CORS - Allow frontend and API domains
CORS_ORIGINS=https://jijiayi.online,https://www.jijiayi.online,https://api.jijiayi.online,http://api.jijiayi.online

# ----------------------------------------------------------------------------
# AI Provider Configuration
# ----------------------------------------------------------------------------
# Choose: deepseek or openai
AI_PROVIDER=deepseek

# Default AI model
AI_DEFAULT_MODEL=deepseek-chat
AI_TIMEOUT=30

# Deepseek Configuration (when AI_PROVIDER=deepseek)
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY_HERE
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI Configuration (when AI_PROVIDER=openai)
# OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# ----------------------------------------------------------------------------
# Volces Ark API Configuration (Image Generation)
# ----------------------------------------------------------------------------
VOLCES_API_KEY=YOUR_VOLCES_API_KEY_HERE
VOLCES_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCES_IMAGE_MODEL=doubao-seedream-5-0-260128

# ----------------------------------------------------------------------------
# SMTP Configuration (Email Password Reset)
# ----------------------------------------------------------------------------
# Get Gmail App Password: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM=Inner Garden <noreply@jijiayi.online>
SMTP_USE_TLS=true
SMTP_ENABLED=false

# ----------------------------------------------------------------------------
# Docker/Deployment Configuration
# ----------------------------------------------------------------------------
HTTP_PORT=80
HTTPS_PORT=443

# ----------------------------------------------------------------------------
# Frontend Configuration
# ----------------------------------------------------------------------------
# API base URL - use API subdomain in production
VITE_API_BASE_URL=https://api.jijiayi.online/api/v1
